# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# Generated browser assets.
/priv/static/assets/
/priv/static/dashboard/

# Local runtime logs.
/log/
/logs/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Elixir language server and tooling.
/.elixir_ls/
/.fetch/

# Editor / OS temporary files.
.DS_Store
*.swp
*.swo
*~

# IDE folders.
.idea/
.vscode/

# Vite cache.
dashboard/.vite/
/bin/

# Local environment and auth artifacts.
.env
.env.*
.secrets
.credentials
.symphony_settings.json
.symphony_settings.json.migrated
symphony.db
status.txt
.codex/original-user-prompt.txt

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
symphony_elixir-*.tar

# Cloudflare Workers.
workers/*/node_modules/
workers/*/.wrangler/

# Root-level Wrangler/miniflare state (from running wrangler dev at repo root).
.wrangler/
node_modules/.cache/
node_modules/.mf/
