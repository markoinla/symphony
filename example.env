# Symphony Environment Configuration
# Copy to .env and fill in values: cp example.env .env

# === Required (one of the following) ===

# Linear API key for issue tracking (fallback if OAuth is not configured)
LINEAR_API_KEY=

# Dashboard password (leave empty to disable auth)
# Generate one with: openssl rand -base64 16
SYMPHONY_AUTH_PASSWORD=

# Phoenix session signing key (must be at least 64 bytes)
# Generate one with: openssl rand -base64 64
SYMPHONY_SECRET_KEY_BASE=

# === Host CLI tool paths ===
# Find with: which claude, which codex

# Claude CLI binary path
CLAUDE_BIN=/usr/local/bin/claude

# Claude auth/config directory
CLAUDE_HOME=~/.claude

# Codex CLI binary path (optional if using claude engine)
# CODEX_BIN=/usr/local/bin/codex

# Codex auth/config directory (optional if using claude engine)
# CODEX_HOME=~/.codex

# === Git access ===

GIT_CONFIG=~/.gitconfig
SSH_DIR=~/.ssh

# === Optional ===

# Linear webhook secret (for linear_agent webhook mode)
# LINEAR_WEBHOOK_SECRET=

# Linear OAuth app credentials (preferred auth — configure via dashboard or env)
# When OAuth is connected, LINEAR_API_KEY is not required.
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=
# LINEAR_OAUTH_TOKEN=

# Custom Linear API endpoint
# LINEAR_ENDPOINT=https://api.linear.app/graphql
